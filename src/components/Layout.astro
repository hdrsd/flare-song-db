---
import "@/styles/global.css";
import { ClientRouter } from "astro:transitions";
import GlobalPlayer from "@/components/GlobalPlayer.astro";
import { getLocale, useT } from "@/lib/i18n";

interface Props {
  title?: string;
  active?: "home" | "songs" | "search" | "watch" | "playlist" | "discography" | "statistics";
}
const { title, active } = Astro.props;
const locale = getLocale(Astro.currentLocale);
const t = useT(locale);

// 로케일 토글: ko는 /ko 접두사, ja는 접두사 없음(astro.config defaultLocale=ja)
const path = Astro.url.pathname.replace(/^\/ko/, "") || "/";
const jaHref = path;
const koHref = "/ko" + (path === "/" ? "" : path);

const nav = [
  { key: "home", href: locale === "ko" ? "/ko" : "/", label: t("nav.home") },
  { key: "songs", href: (locale === "ko" ? "/ko" : "") + "/songs", label: t("nav.songs") },
  { key: "discography", href: (locale === "ko" ? "/ko" : "") + "/discography", label: t("nav.discography") },
  { key: "search", href: (locale === "ko" ? "/ko" : "") + "/search", label: t("nav.search") },
  { key: "watch", href: (locale === "ko" ? "/ko" : "") + "/watch", label: t("nav.watch") },
  { key: "playlist", href: (locale === "ko" ? "/ko" : "") + "/playlist", label: t("nav.playlist") },
  { key: "statistics", href: (locale === "ko" ? "/ko" : "") + "/statistics", label: t("nav.statistics") },
];
const fullTitle = title ? `${title} | ${t("site.name")}` : t("site.name");
---

<!doctype html>
<html lang={locale}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{fullTitle}</title>
    <meta name="description" content={t("site.tagline")} />
    <link rel="icon" href="/favicon.svg" />
    <meta name="theme-color" id="metaThemeColor" content="#0f1014" />
    <ClientRouter />
    <script is:inline>
      // 무플래시: 저장값 또는 시스템 설정으로 테마 결정
      (function () {
        try {
          var saved = localStorage.getItem("flare:theme");
          var sysLight = window.matchMedia && matchMedia("(prefers-color-scheme: light)").matches;
          var theme = saved === "light" || saved === "dark" ? saved : sysLight ? "light" : "dark";
          document.documentElement.dataset.theme = theme;
          var m = document.getElementById("metaThemeColor");
          if (m) m.setAttribute("content", theme === "light" ? "#f6f7f9" : "#0f1014");
        } catch (e) {}
      })();
    </script>
  </head>
  <body data-page={active}>
    <header class="site-header">
      <div class="inner">
        <a class="brand" href={locale === "ko" ? "/ko" : "/"}>🔥 {t("site.name")}</a>
        <button class="nav-toggle" id="navToggle" aria-label="Menu">☰</button>
        <nav class="nav" id="nav">
          {nav.map((n) => (
            <a href={n.href} class={active === n.key ? "active" : ""}>{n.label}</a>
          ))}
        </nav>
        <div class="lang">
          <a href={jaHref} class={locale === "ja" ? "active" : ""}>JA</a>
          <a href={koHref} class={locale === "ko" ? "active" : ""}>KO</a>
        </div>
        <button id="themeToggle" class="theme-toggle" aria-label="Theme">🌙</button>
      </div>
    </header>
    <script is:inline>
      (() => {
        const nt = document.getElementById("navToggle");
        const nav = document.getElementById("nav");
        if (nt && nav) nt.addEventListener("click", () => nav.classList.toggle("open"));
      })();
      (() => {
        const btn = document.getElementById("themeToggle");
        if (!btn) return;
        const cur = () => document.documentElement.dataset.theme || "dark";
        const sync = () => (btn.textContent = cur() === "light" ? "☀️" : "🌙");
        sync();
        btn.addEventListener("click", () => {
          const next = cur() === "light" ? "dark" : "light";
          document.documentElement.dataset.theme = next;
          const m = document.getElementById("metaThemeColor");
          if (m) m.setAttribute("content", next === "light" ? "#f6f7f9" : "#0f1014");
          try { localStorage.setItem("flare:theme", next); } catch (e) {}
          sync();
        });
      })();
    </script>

    <main class="container">
      <slot />
    </main>

    <footer class="site-footer">
      <div class="container">{t("disclaimer")}</div>
    </footer>

    <GlobalPlayer />

    <button id="toTop" class="to-top" aria-label="Top" hidden>↑</button>
    <script is:inline>
      (() => {
        const b = document.getElementById("toTop");
        if (!b) return;
        const upd = () => { b.hidden = window.scrollY < 400; };
        window.onscroll = upd; // SPA 이동 시 중복 방지(단일 핸들러)
        b.addEventListener("click", () => scrollTo({ top: 0, behavior: "smooth" }));
        upd();
      })();
    </script>
  </body>
</html>
