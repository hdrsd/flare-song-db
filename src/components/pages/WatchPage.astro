---
import Layout from "@/components/Layout.astro";
import { getLocale, useT } from "@/lib/i18n";

const locale = getLocale(Astro.currentLocale);
const t = useT(locale);
const base = locale === "ko" ? "/ko" : "";

const labels = {
  queue: t("watch.queue"),
  thisVideo: t("watch.thisVideo"),
  openYoutube: t("watch.openYoutube"),
  add: t("watch.addToPlaylist"),
  added: t("watch.added"),
  playingList: t("watch.playingList"),
  plays: t("watch.plays", { n: "%n%" }),
  newPl: t("playlist.new"),
  name: t("playlist.name"),
  create: t("playlist.create"),
  save: t("playlist.save"),
  saved: t("playlist.saved"),
  pick: t("watch.pick"),
};
---

<Layout title={t("watch.title")} active="watch">
  <h1>{t("watch.title")}</h1>

  <div id="shareBanner" class="share-banner" hidden></div>

  <div class="watch-c">
    <div class="now" id="now">
      <div class="nt" id="nowTitle">{t("watch.pick")}</div>
      <div class="na" id="nowArtist"></div>
      <div class="nmeta" id="nowMeta"></div>
      <div class="nactions" id="nowActions" hidden>
        <button id="favBtn" class="np-btn" title={t("watch.favorite")}>♡</button>
        <a id="ytLink" class="np-btn" target="_blank" rel="noopener">▶ {labels.openYoutube}</a>
        <button id="addBtn" class="np-btn">＋ {labels.add}</button>
      </div>
    </div>

    <div class="segments" id="segBox" hidden>
      <div class="seg-head">{labels.thisVideo} <span id="segCount"></span></div>
      <div class="seg-list" id="segList"></div>
    </div>

    <div class="toolbar">
      <label><input type="checkbox" id="songMode" checked /> {t("watch.songMode")}</label>
      <button id="shuffleBtn" class="np-btn">🔀 {t("watch.shuffle")}</button>
      <button id="repeatBtn" class="np-btn" title={t("watch.repeat")}>🔁</button>
    </div>
    <div class="qhead"><span id="qcount">…</span></div>
    <div class="queue" id="queue"></div>
    <div class="more-wrap"><button id="more" class="more-btn" hidden>{t("songs.more")}</button></div>
  </div>

  <div id="plModal" class="modal-overlay" hidden>
    <div class="modal">
      <div class="modal-head"><strong>{labels.add}</strong><button id="plClose" class="x">✕</button></div>
      <div id="plList" class="modal-list"></div>
      <div class="modal-new">
        <input id="plNewName" type="text" placeholder={labels.name} />
        <button id="plCreate" class="np-btn primary">{labels.create}</button>
      </div>
    </div>
  </div>

  <div id="cfg" data-base={base} data-labels={JSON.stringify(labels)} hidden></div>

  <script>
    import { getPlayer } from "@/lib/globalPlayer";
    import { thumbUrl, fmtTime, fmtDate, escapeHtml, tagLabel, type CompactSong } from "@/lib/songs.shared";
    import { loadPlaylists, createPlaylist, addToPlaylist, isInPlaylist, getPlaylist, decodeShare } from "@/lib/playlists";

    const PAGE = 100;
    let rendered = 0;

    async function setup() {
      const cfg = document.getElementById("cfg");
      if (!cfg) return; // watch 페이지 아님
      const base = cfg.dataset.base ?? "";
      const locale = base === "/ko" ? "ko" : "ja";
      const L = JSON.parse(cfg.dataset.labels!) as Record<string, string>;
      const searchBase = `${base}/search`;
      const $ = (id: string) => document.getElementById(id)!;

      const p = getPlayer();
      await p.indexReady;

      const queueEl = $("queue"), qcount = $("qcount"), moreBtn = $("more") as HTMLButtonElement;
      const songModeEl = $("songMode") as HTMLInputElement, shuffleBtn = $("shuffleBtn"), repeatBtn = $("repeatBtn");
      const nowTitle = $("nowTitle"), nowArtist = $("nowArtist"), nowMeta = $("nowMeta"), nowActions = $("nowActions");
      const ytLink = $("ytLink") as HTMLAnchorElement, favBtn = $("favBtn"), addBtn = $("addBtn");
      const segBox = $("segBox"), segList = $("segList"), segCount = $("segCount");
      const shareBanner = $("shareBanner");

      // 큐 소스 결정
      const params = new URLSearchParams(location.search);
      const id = params.get("id"), listId = params.get("list"), shareParam = params.get("share");
      let queue: CompactSong[] = [];
      if (params.get("fav") === "1") {
        const ids = JSON.parse(localStorage.getItem("flare:favorites:v1") || "[]");
        queue = ids.map((x: string) => p.byId.get(x)).filter(Boolean) as CompactSong[];
      } else if (listId) {
        queue = (getPlaylist(listId)?.songIds ?? []).map((x) => p.byId.get(x)).filter(Boolean) as CompactSong[];
      } else if (shareParam) {
        const dec = decodeShare(shareParam);
        if (dec) {
          queue = dec.songIds.map((x) => p.byId.get(x)).filter(Boolean) as CompactSong[];
          shareBanner.hidden = false;
          shareBanner.innerHTML = `<span>📥 <strong>${escapeHtml(dec.name)}</strong> (${queue.length})</span>
            <button id="saveShared" class="np-btn primary">${L.save}</button>`;
          $("saveShared").onclick = () => { createPlaylist(dec.name, dec.songIds); shareBanner.innerHTML = `<span>✓ ${L.saved}</span>`; };
        }
      }
      if (queue.length) p.setQueue(queue); else p.ensureQueue();

      if (params.get("shuffle") === "1") p.setShuffle(true);
      if (id) p.playId(id);
      else if (queue.length && !p.song) p.playIndex(0);

      // 컨트롤 ↔ 플레이어 상태 동기화
      songModeEl.checked = p.songMode;
      shuffleBtn.classList.toggle("active", p.shuffle);
      function updRepeat() { repeatBtn.classList.toggle("active", p.repeat > 0); repeatBtn.textContent = p.repeat === 2 ? "🔂" : "🔁"; }
      updRepeat();
      songModeEl.onchange = () => p.setSongMode(songModeEl.checked);
      shuffleBtn.onclick = () => { p.setShuffle(!p.shuffle); shuffleBtn.classList.toggle("active", p.shuffle); };
      repeatBtn.onclick = () => { p.cycleRepeat(); updRepeat(); };
      favBtn.onclick = () => p.toggleFav();
      addBtn.onclick = openAddModal;

      // 큐 렌더
      function rowHtml(s: CompactSong, i: number) {
        const dur = s.e > s.st ? ` · ${fmtTime(s.e - s.st)}` : "";
        return `<div class="qitem" data-i="${i}"><img src="${thumbUrl(s.v)}" alt="" loading="lazy"
          onerror="this.onerror=null;this.src='https://i.ytimg.com/vi/${s.v}/hqdefault.jpg'" />
          <div><div class="qt">${escapeHtml(s.t)}</div><div class="qa">${escapeHtml(s.a)}${dur}</div></div></div>`;
      }
      function renderUpTo(n: number) {
        const q = p.queue, end = Math.min(n, q.length);
        let html = ""; for (let i = rendered; i < end; i++) html += rowHtml(q[i], i);
        queueEl.insertAdjacentHTML("beforeend", html); rendered = end;
        moreBtn.hidden = rendered >= q.length;
      }
      rendered = 0; queueEl.innerHTML = "";
      qcount.textContent = `${L.queue} (${p.queue.length})`;
      renderUpTo(PAGE);
      moreBtn.onclick = () => renderUpTo(rendered + PAGE);
      queueEl.onclick = (e) => { const el = (e.target as HTMLElement).closest<HTMLElement>(".qitem"); if (el) p.playIndex(Number(el.dataset.i)); };
      segList.onclick = (e) => { const el = (e.target as HTMLElement).closest<HTMLElement>(".seg"); if (el) p.seekSeg(el.dataset.sid!); };

      // now-playing / 세그먼트 / 하이라이트
      function renderNow() {
        const s = p.song;
        if (!s) { nowTitle.textContent = L.pick; nowArtist.textContent = ""; nowMeta.innerHTML = ""; nowActions.hidden = true; segBox.hidden = true; return; }
        nowTitle.textContent = s.t; nowArtist.textContent = s.a;
        const tags = s.g.map((tag) => `<a class="badge tag" href="${searchBase}?q=tag:${encodeURIComponent(tag)}">${escapeHtml(tagLabel(tag, locale))}</a>`).join("");
        const sing = s.s && s.s !== s.a ? `<span class="np-sing">🎤 ${escapeHtml(s.s)}</span>` : "";
        nowMeta.innerHTML = `<span class="badge date">${fmtDate(s.d)}</span>${sing}${tags}`;
        ytLink.href = `https://www.youtube.com/watch?v=${s.v}&t=${s.st}s`;
        favBtn.textContent = p.isFav() ? "♥" : "♡"; favBtn.classList.toggle("active", p.isFav());
        nowActions.hidden = false;
        // 세그먼트
        const segs = p.segs(s.v);
        if (segs.length <= 1) segBox.hidden = true;
        else {
          segBox.hidden = false; segCount.textContent = `(${segs.length})`;
          segList.innerHTML = segs.map((g) => `<div class="seg${g.id === s.id ? " active" : ""}" data-sid="${g.id}"><span class="seg-ts">${fmtTime(g.st)}</span><span class="seg-t">${escapeHtml(g.t)}</span></div>`).join("");
        }
        // 큐 하이라이트
        queueEl.querySelectorAll(".qitem.active").forEach((el) => el.classList.remove("active"));
        if (p.idx >= 0) { renderUpTo(p.idx + 1); const el = queueEl.querySelector<HTMLElement>(`.qitem[data-i="${p.idx}"]`); el?.classList.add("active"); el?.scrollIntoView({ block: "nearest" }); }
      }
      renderNow();
      document.removeEventListener("flare:change", (window as any).__watchSync);
      (window as any).__watchSync = renderNow;
      document.addEventListener("flare:change", renderNow);

      // 플레이리스트 추가 모달
      const plModal = $("plModal"), plList = $("plList"), plNewName = $("plNewName") as HTMLInputElement;
      function renderModalList() {
        const pls = loadPlaylists();
        plList.innerHTML = pls.length ? pls.map((pl) => {
          const inIt = p.song && isInPlaylist(pl.id, p.song.id);
          return `<button class="pl-row${inIt ? " in" : ""}" data-pid="${pl.id}"><span>${escapeHtml(pl.name)}</span><span class="pl-row-r">${inIt ? "✓" : "＋"} <small>${pl.songIds.length}</small></span></button>`;
        }).join("") : `<p class="modal-empty">${escapeHtml(L.newPl)} ↓</p>`;
      }
      function openAddModal() { if (!p.song) return; renderModalList(); plModal.hidden = false; plNewName.value = ""; }
      plList.onclick = (e) => { const el = (e.target as HTMLElement).closest<HTMLElement>(".pl-row"); if (el && p.song) { addToPlaylist(el.dataset.pid!, p.song.id); renderModalList(); } };
      $("plCreate").onclick = () => { if (!p.song) return; const n = plNewName.value.trim(); if (!n) return; createPlaylist(n, [p.song.id]); plNewName.value = ""; renderModalList(); };
      $("plClose").onclick = () => (plModal.hidden = true);
      plModal.onclick = (e) => { if (e.target === plModal) plModal.hidden = true; };
    }

    document.addEventListener("astro:page-load", setup);
  </script>
</Layout>
